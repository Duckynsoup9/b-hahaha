  <script>
    let allFavorites = JSON.parse(localStorage.getItem('favoritesV2')) || {};

    function saveFavorites() {
      localStorage.setItem('favoritesV2', JSON.stringify(allFavorites));
    }

    function getCurrentTabFavorites() {
      return allFavorites[currentTab] || [];
    }

    function toggleFavorite(game, event) {
      event.stopPropagation();

      if (!allFavorites[currentTab]) {
        allFavorites[currentTab] = [];
      }

      const tabFavs = allFavorites[currentTab];
      const index = tabFavs.findIndex(f => f.name === game.name);

      if (index > -1) {
        tabFavs.splice(index, 1);
      } else {
        tabFavs.push(game);
      }

      saveFavorites();
      renderFavorites();

      const searchQuery = document.getElementById('searchInput').value;
      if (searchQuery.trim() === '') {
        renderGames(games);
      } else {
        filterGames(searchQuery);
      }
    }

    function isFavorited(gameName) {
      return getCurrentTabFavorites().some(f => f.name === gameName);
    }

    function renderFavorites() {
      const favoritesSection = document.getElementById('favoritesSection');
      const favoritesGrid = document.getElementById('favoritesGrid');
      const tabFavs = getCurrentTabFavorites();

      if (tabFavs.length === 0) {
        favoritesSection.style.display = 'none';
        return;
      }

      favoritesSection.style.display = 'block';
      favoritesGrid.innerHTML = '';

      tabFavs.forEach((game) => {
        const card = createGameCard(game, true);
        favoritesGrid.appendChild(card);
      });
    }

    function createGameCard(game, isFavoriteSection = false) {
      const card = document.createElement('div');
      card.className = 'game-card';

      const img = document.createElement('img');
      img.src = game.image;
      img.alt = game.name;
      img.className = 'game-image';
      img.loading = 'lazy';
      card.appendChild(img);

      const starBtn = document.createElement('button');
      starBtn.className = 'star-btn' + (isFavorited(game.name) ? ' active' : '');
      starBtn.innerHTML = '★';
      starBtn.title = isFavorited(game.name) ? 'Remove from favorites' : 'Add to favorites';
      starBtn.onclick = (e) => toggleFavorite(game, e);
      card.appendChild(starBtn);

      const info = document.createElement('div');
      info.className = 'game-info';

      const title = document.createElement('div');
      title.className = 'game-title';
      title.textContent = game.name;
      info.appendChild(title);

      const meta = document.createElement('div');
      meta.className = 'game-meta';
      meta.innerHTML = ``;
      info.appendChild(meta);

      card.appendChild(info);

      if (currentTab === 'minecraft') {
        const downloadBtn = document.createElement('div');
        downloadBtn.className = 'download-overlay';
        card.appendChild(downloadBtn);
        card.addEventListener('click', () => {
          playSound('click');
          downloadMod(game.file);
        });
      } else {
        const playBtn = document.createElement('div');
        playBtn.className = 'play-overlay';
        card.appendChild(playBtn);
        card.addEventListener('click', () => {
          playSound('click');
          loadGame(game.file, game.name);
        });
      }

      card.addEventListener('mouseenter', () => playSound('hover'));

      return card;
    }

    let introComplete = false;

    function hideIntro() {
      const intro = document.getElementById('introOverlay');
      const introAudio = document.getElementById('introAudio');
      intro.classList.add('hide');
      introAudio.pause();
      introAudio.currentTime = 0;

      document.body.classList.remove('intro-active');

      setTimeout(() => {
        intro.style.display = 'none';
        introComplete = true;
        if (ambianceEnabled && !isGamePlaying && !isMoviePlaying) {
          playAmbiance();
        }
      }, 600);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const introVideo = document.getElementById('introVideo');
      const introAudio = document.getElementById('introAudio');
      const introOverlay = document.getElementById('introOverlay');
      const skipIntroBtn = document.getElementById('skipIntroBtn');

      skipIntroBtn.addEventListener('click', () => {
        playSound('click');
        hideIntro();
      });

      // Check if intro is enabled (default: false/disabled)
      const introEnabled = localStorage.getItem('introEnabled') === 'true';

      if (!introEnabled) {
        // Skip intro immediately
        introOverlay.style.display = 'none';
        document.body.classList.remove('intro-active');
        introComplete = true;
        return;
      }

      const introVideoUrl = 'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/intro.mp4';
      const introAudioUrl = 'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/intro.mp3';

      if (introVideoUrl) {
        introVideo.querySelector('source').src = introVideoUrl;
        introVideo.load();

        if (introAudioUrl) {
          introAudio.src = introAudioUrl;
          introAudio.load();
        }

        introVideo.addEventListener('play', () => {
          if (introAudioUrl && introAudio.paused) {
            introAudio.play().catch(err => console.log('Audio playback prevented:', err));
          }
        }, { once: true });

        introVideo.addEventListener('ended', () => {
          hideIntro();
        }, { once: true });

        setTimeout(() => {
          if (introOverlay.style.display !== 'none') {
            hideIntro();
          }
        }, 20000);
      } else {
        setTimeout(() => {
          hideIntro();
        }, 2000);
      }
    });

    function showLoadingOverlay(text = 'Loading...') {
      const overlay = document.getElementById('loadingOverlay');
      document.getElementById('loadingText').textContent = text;
      overlay.classList.add('active');
    }

    function hideLoadingOverlay() {
      const overlay = document.getElementById('loadingOverlay');
      overlay.classList.remove('active');
    }

    function playSound(type) {
      const audioContext = new (window.AudioContext || window.webkitAudioContext)();
      const now = audioContext.currentTime;
      const oscillator = audioContext.createOscillator();
      const gain = audioContext.createGain();

      oscillator.connect(gain);
      gain.connect(audioContext.destination);

      if (type === 'click') {
        oscillator.frequency.setValueAtTime(800, now);
        oscillator.frequency.exponentialRampToValueAtTime(400, now + 0.1);
        gain.gain.setValueAtTime(0.1, now);
        gain.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
        oscillator.start(now);
        oscillator.stop(now + 0.1);
      } else if (type === 'hover') {
        oscillator.frequency.setValueAtTime(600, now);
        oscillator.frequency.exponentialRampToValueAtTime(800, now + 0.05);
        gain.gain.setValueAtTime(0.05, now);
        gain.gain.exponentialRampToValueAtTime(0.01, now + 0.05);
        oscillator.start(now);
        oscillator.stop(now + 0.05);
      }
    }

    function createSpaceBackground() {
      const bg = document.getElementById('spaceBackground');
      const stars = [];
      const repelRadius = 150;
      const repelForce = 5;

      for (let i = 0; i < 150; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        const size = Math.random() * 2 + 1;
        star.style.width = size + 'px';
        star.style.height = size + 'px';

        const x = Math.random() * window.innerWidth;
        const y = Math.random() * window.innerHeight;
        star.style.left = x + 'px';
        star.style.top = y + 'px';
        star.style.position = 'fixed';
        star.style.animation = `twinkle ${Math.random() * 2 + 2}s infinite`;

        bg.appendChild(star);

        stars.push({
          element: star,
          x: x,
          y: y,
          baseX: x,
          baseY: y,
          vx: 0,
          vy: 0,
          driftX: (Math.random() - 0.5) * 0.5,
          driftY: (Math.random() - 0.5) * 0.5,
          size: size
        });
      }

      const nebulas = [
        { class: 'nebula-purple', size: 400, x: 10, y: 20 },
        { class: 'nebula-cyan', size: 350, x: 70, y: 30 },
        { class: 'nebula-pink', size: 300, x: 40, y: 70 }
      ];

      nebulas.forEach(nebula => {
        const el = document.createElement('div');
        el.className = 'nebula ' + nebula.class;
        el.style.width = nebula.size + 'px';
        el.style.height = nebula.size + 'px';
        el.style.left = nebula.x + '%';
        el.style.top = nebula.y + '%';
        el.style.transform = 'translate(-50%, -50%)';
        bg.appendChild(el);
      });

      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      function animateStars() {
        stars.forEach(star => {
          star.baseX += star.driftX;
          star.baseY += star.driftY;

          if (star.baseX < 0) star.baseX = window.innerWidth;
          if (star.baseX > window.innerWidth) star.baseX = 0;
          if (star.baseY < 0) star.baseY = window.innerHeight;
          if (star.baseY > window.innerHeight) star.baseY = 0;

          const dx = star.x - mouseX;
          const dy = star.y - mouseY;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < repelRadius && distance > 0) {
            const angle = Math.atan2(dy, dx);
            const force = (repelRadius - distance) / repelRadius * repelForce;
            star.vx = Math.cos(angle) * force;
            star.vy = Math.sin(angle) * force;
          } else {
            star.vx += (star.baseX - star.x) * 0.02;
            star.vy += (star.baseY - star.y) * 0.02;
            star.vx *= 0.92;
            star.vy *= 0.92;
          }

          star.x += star.vx;
          star.y += star.vy;

          star.element.style.transform = `translate(${star.x}px, ${star.y}px)`;
        });

        requestAnimationFrame(animateStars);
      }

      animateStars();
    }

    function updateClock() {
      const now = new Date();
      const hours = now.getHours();
      const minutes = String(now.getMinutes()).padStart(2, '0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours % 12 || 12;
      document.getElementById('clock').textContent = `${displayHours}:${minutes} ${ampm}`;
    }
    setInterval(updateClock, 1000);
    updateClock();

    let games = [];
    let allContent = [];
    let currentGameFile = null;
    let isFullscreen = false;
    let cursorHidden = false;
    let currentTab = 'games';
    let heroCycleInterval = null;
    let isGamePlaying = false;
    let isMoviePlaying = false;
    let ambianceEnabled = false;
    let ambianceStarted = false;

    const v = Date.now();
    const CONTENT_URLS = {
      games:     `https://cdn.jsdelivr.net/gh/greeniYT/gug@main/json/game.json`,
      movies:    `https://cdn.jsdelivr.net/gh/greeniYT/gug@main/json/movie.json`,
      minecraft: `https://cdn.jsdelivr.net/gh/greeniYT/gug@main/json/mc-mods.json`,
      other:     `https://cdn.jsdelivr.net/gh/greeniYT/gug@main/json/apps.json`
    };
    const AMBIANCE_URLS = [
      'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/ambiance.mp3',
      'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/ambiance2.mp3',
      'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/ambiance3.mp3',
      'https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/ambiance4.mp3'
    ];

    const ambianceAudio = document.getElementById('ambianceAudio');
    ambianceAudio.src = AMBIANCE_URLS[Math.floor(Math.random() * AMBIANCE_URLS.length)];
    ambianceAudio.volume = 0.5;
    ambianceAudio.loop = true;

    ambianceAudio.addEventListener('ended', () => {
      ambianceAudio.src = AMBIANCE_URLS[Math.floor(Math.random() * AMBIANCE_URLS.length)];
      ambianceAudio.play().catch(err => console.log('Ambiance playback failed:', err));
    });

    function loadSettings() {
      const savedLightMode = localStorage.getItem('lightMode') === 'true';
      // Default false (disabled) unless explicitly saved as 'true'
      const savedAmbiance = localStorage.getItem('ambianceEnabled') === 'true';
      const savedVolume = localStorage.getItem('ambianceVolume') || '50';
      // Default false (disabled) unless explicitly saved as 'true'
      const savedIntro = localStorage.getItem('introEnabled') === 'true';

      if (savedLightMode) {
        document.body.classList.add('light-mode');
        document.getElementById('lightModeToggle').checked = true;
      }

      ambianceEnabled = savedAmbiance;
      document.getElementById('ambianceToggle').checked = ambianceEnabled;
      document.getElementById('volumeSlider').value = savedVolume;
      document.getElementById('volumeValue').textContent = savedVolume + '%';
      ambianceAudio.volume = parseInt(savedVolume) / 100;

      document.getElementById('introToggle').checked = savedIntro;
    }

    function saveSettings() {
      localStorage.setItem('lightMode', document.getElementById('lightModeToggle').checked);
      localStorage.setItem('ambianceEnabled', document.getElementById('ambianceToggle').checked);
      localStorage.setItem('ambianceVolume', document.getElementById('volumeSlider').value);
      localStorage.setItem('introEnabled', document.getElementById('introToggle').checked);
    }

    document.getElementById('lightModeToggle').addEventListener('change', (e) => {
      playSound('click');
      document.body.classList.toggle('light-mode', e.target.checked);
      saveSettings();
    });

    document.getElementById('introToggle').addEventListener('change', (e) => {
      playSound('click');
      saveSettings();
    });

    document.getElementById('ambianceToggle').addEventListener('change', (e) => {
      playSound('click');
      ambianceEnabled = e.target.checked;
      if (ambianceEnabled && introComplete && !isGamePlaying && !isMoviePlaying) {
        playAmbiance();
      } else {
        pauseAmbiance();
      }
      saveSettings();
    });

    document.getElementById('volumeSlider').addEventListener('input', (e) => {
      const volume = parseInt(e.target.value);
      document.getElementById('volumeValue').textContent = volume + '%';
      ambianceAudio.volume = volume / 100;
      saveSettings();
    });

    function playAmbiance() {
      if (ambianceEnabled && introComplete && !isGamePlaying && !isMoviePlaying) {
        ambianceAudio.play().catch(err => console.log('Ambiance autoplay prevented:', err));
        ambianceStarted = true;
      }
    }

    function pauseAmbiance() {
      ambianceAudio.pause();
    }

    document.getElementById('menuBtn').addEventListener('click', () => {
      playSound('click');
      document.getElementById('settingsModal').classList.add('active');
    });

    function closeSettings() {
      playSound('click');
      document.getElementById('settingsModal').classList.remove('active');
    }

    window.addEventListener('click', (e) => {
      const modal = document.getElementById('settingsModal');
      if (e.target === modal) {
        closeSettings();
      }
    });

    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('button, a, .game-card, .tab-btn, .contact-link');
      buttons.forEach(btn => {
        btn.addEventListener('mouseenter', () => playSound('hover'));
        btn.addEventListener('click', () => playSound('click'));
      });
    });

    async function loadContent(tab) {
      currentTab = tab;
      const url = CONTENT_URLS[tab];

      try {
        const response = await fetch(url);
        if (!response.ok) throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        games = await response.json();

        if (!Array.isArray(games) || games.length === 0) {
          throw new Error('No content found in JSON');
        }

        renderGames(games);
        renderFavorites(); 
        setupHero(games);
      } catch (error) {
        console.error('Error loading content:', error);
        document.getElementById('gamesList').innerHTML = `
          <div class="error-message" style="display: block; background: transparent; flex: 1;">
            <div style="font-size: 24px; margin-bottom: 10px;">⚠️ Error Loading Content</div>
            <div>${error.message}</div>
            <button onclick="loadContent('${tab}')">Retry</button>
          </div>
        `;
      }
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        playSound('click');
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        updateSectionTitle(e.target.dataset.tab);
        loadContent(e.target.dataset.tab);
      });
    });

    function updateSectionTitle(tab) {
      const titles = {
        games: 'Games',
        movies: 'Movies',
        minecraft: 'Mods',
        other: 'Apps'
      };
      document.getElementById('sectionTitle').textContent = titles[tab] || 'Launcher';
    }

    function setupHero(gamesList) {
      if (!gamesList || gamesList.length === 0) return;

      if (heroCycleInterval) clearInterval(heroCycleInterval);

      allContent = gamesList;
      let currentIndex = 0;

      updateHeroDisplay(gamesList[currentIndex]);

      heroCycleInterval = setInterval(() => {
        currentIndex = (currentIndex + 1) % gamesList.length;
        updateHeroDisplay(gamesList[currentIndex]);
      }, 5000);
    }

    function updateHeroDisplay(item) {
      const hero = document.getElementById('heroSection');
      document.getElementById('heroImage').src = item.image;
      document.getElementById('heroTitle').textContent = item.name;

      if (currentTab === 'minecraft') {
        document.getElementById('heroSubtitle').textContent = 'Click to download';
        hero.onclick = () => {
          playSound('click');
          downloadMod(item.file);
        };
      } else {
        document.getElementById('heroSubtitle').textContent = 'Click to launch';
        hero.onclick = () => {
          playSound('click');
          loadGame(item.file, item.name);
        };
      }

      hero.classList.add('active');

      const progress = document.getElementById('heroProgress');
      progress.style.animation = 'none';
      setTimeout(() => {
        progress.style.animation = 'progressBar 5s linear';
      }, 10);
    }

    function renderGames(gamesToRender) {
      const container = document.getElementById('gamesList');
      const noResults = document.getElementById('noResults');

      if (gamesToRender.length === 0) {
        container.innerHTML = '';
        noResults.style.display = 'block';
        return;
      }

      noResults.style.display = 'none';
      container.innerHTML = '';

      gamesToRender.forEach((game, index) => {
        const card = createGameCard(game);
        container.appendChild(card);
      });
    }

    function filterGames(query) {
      const lowerQuery = query.toLowerCase().trim();
      const filtered = lowerQuery === '' ? games : games.filter(game =>
        game.name.toLowerCase().includes(lowerQuery)
      );
      renderGames(filtered);
    }

    document.getElementById('searchInput').addEventListener('input', (e) => {
      filterGames(e.target.value);
    });

    async function downloadMod(file) {
      try {
        const response = await fetch(file);
        if (!response.ok) throw new Error(`Failed to download: ${response.statusText}`);
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = file.split('/').pop() || 'minecraft-mod';
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
      } catch (error) {
        alert('Error downloading mod: ' + error.message);
      }
    }

    async function loadGame(file, gameName = 'Game') {
      currentGameFile = file;
      showLoadingOverlay(`Loading ${gameName}...`);

      try {
        const gameContent = document.getElementById('gameContent');
        gameContent.innerHTML = '';

        isMoviePlaying = file.includes('drive.google.com');
        isGamePlaying = !isMoviePlaying;

        if (ambianceEnabled) {
          pauseAmbiance();
        }

        await new Promise(resolve => setTimeout(resolve, 800));

        if (file.includes('drive.google.com')) {
          const iframe = document.createElement('iframe');
          iframe.src = file;
          iframe.style.width = '100%';
          iframe.style.height = '100%';
          iframe.style.border = 'none';
          iframe.allow = 'fullscreen';
          gameContent.appendChild(iframe);
        } else {
          const response = await fetch(file, { cache: "no-store" });
          if (!response.ok) throw new Error(`Failed to load ${file}: ${response.statusText}`);
          const text = await response.text();

          const iframe = document.createElement('iframe');
          iframe.style.width = '100%';
          iframe.style.height = '100%';
          iframe.style.border = 'none';
          iframe.sandbox.add('allow-scripts', 'allow-same-origin', 'allow-forms', 'allow-popups', 'autoplay', 'fullscreen','camera','microphone','allow-modals', 'allow-pointer-lock');

          gameContent.appendChild(iframe);

          const doc = iframe.contentDocument || iframe.contentWindow.document;
          doc.open();
          doc.write(text);
          doc.close();
        }

        hideLoadingOverlay();
        showOverlay();
      } catch (error) {
        hideLoadingOverlay();
        document.getElementById('gameContent').innerHTML = `
          <div style="color: #ff4444; padding: 20px; text-align: center;">
            <div style="font-size: 24px; margin-bottom: 10px;">⚠ Error</div>
            <div>${error.message}</div>
          </div>
        `;
        showOverlay();
      }
    }

    function showOverlay() {
      const overlay = document.getElementById('gameOverlay');
      overlay.style.display = 'flex';
      isFullscreen = false;
      cursorHidden = false;
      overlay.classList.remove('fullscreen');
      document.getElementById('gameControls').classList.remove('hidden');
      document.getElementById('cursorToggleBtn').textContent = 'Hide Cursor';
      document.body.style.cursor = 'auto';
      overlay.focus();
    }

    function hideOverlay() {
      document.getElementById('gameOverlay').style.display = 'none';
      document.getElementById('gameContent').innerHTML = '';
      document.body.style.cursor = 'auto';
      isGamePlaying = false;
      isMoviePlaying = false;

      if (ambianceEnabled) {
        playAmbiance();
      }

      if (isFullscreen) {
        exitFullscreen();
        isFullscreen = false;
        document.getElementById('gameOverlay').classList.remove('fullscreen');
      }
    }

    document.getElementById('cursorToggleBtn').addEventListener('click', () => {
      playSound('click');
      cursorHidden = !cursorHidden;
      document.body.style.cursor = cursorHidden ? 'none' : 'auto';
      document.getElementById('cursorToggleBtn').textContent = cursorHidden ? 'Show Cursor' : 'Hide Cursor';
    });

    document.getElementById('newTabBtn').addEventListener('click', async () => {
      playSound('click');
      if (!currentGameFile) return;
      try {
        const response = await fetch(currentGameFile, { cache: "no-store" });
        const text = await response.text();
        const modified = text.replace('<head>', `<head>
          <title>Dashboard</title>
          <link rel="icon" type="image/png" href="https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/canvas-fav.png">`);
        const blob = new Blob([modified], { type: 'text/html' });
        window.open(URL.createObjectURL(blob), '_blank');
      } catch (error) {
        alert('Error: ' + error.message);
      }
    });

    document.getElementById('fullscreenGameBtn').addEventListener('click', () => {
      playSound('click');
      const overlay = document.getElementById('gameOverlay');
      const controls = document.getElementById('gameControls');
      if (!isFullscreen) {
        enterFullscreen(overlay);
        controls.classList.add('hidden');
      } else {
        exitFullscreen();
        controls.classList.remove('hidden');
      }
      isFullscreen = !isFullscreen;
      overlay.classList.toggle('fullscreen', isFullscreen);
    });

    document.getElementById('closeGameBtn').addEventListener('click', () => {
      playSound('click');
      hideOverlay();
    });

    function enterFullscreen(element) {
      if (element.requestFullscreen) element.requestFullscreen();
      else if (element.webkitRequestFullscreen) element.webkitRequestFullscreen();
      else if (element.msRequestFullscreen) element.msRequestFullscreen();
    }

    function exitFullscreen() {
      if (document.exitFullscreen) document.exitFullscreen();
      else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
      else if (document.msExitFullscreen) document.msExitFullscreen();
    }

    document.addEventListener('fullscreenchange', () => {
      if (!document.fullscreenElement && isFullscreen) {
        isFullscreen = false;
        document.getElementById('gameOverlay').classList.remove('fullscreen');
        document.getElementById('gameControls').classList.remove('hidden');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.getElementById('gameOverlay').style.display === 'flex') {
        playSound('click');
        hideOverlay();
      }
    });

    createSpaceBackground();
    loadSettings();
    renderFavorites();
    loadContent('games');
  </script>
</body>

</html>

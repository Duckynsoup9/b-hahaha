<!DOCTYPE html>
<html lang="en">
 
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta property="og:title" content="Greeni's Notebook">
  <meta property="og:description" content="Testing...">
  <meta property="og:image" content="https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/bred.webp">
  <meta property="og:url" content="https://grogy-learning-17470093.codehs.me/">
  <meta property="og:type" content="website">
  <title>Greeni's Notebook: Lockdown Browser</title>
  <link rel="icon" type="image/png" href="../assets/favicon.png">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --xbox-green: #107C10;
      --xbox-dark: #0F0F0F;
      --xbox-darker: #050505;
      --xbox-gray: #1F1F1F;
      --xbox-light: #FFFFFF;
      --xbox-accent: #9BF00B;
    }

    body {
      font-family: 'Segoe UI Variable', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--xbox-darker);
      color: var(--xbox-light);
      min-height: 100vh;
      overflow-x: hidden;
      cursor: url('https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/c.png') 0 0, auto;
    }

    body.cursor-clicking {
      cursor: url('https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/cl.png') 0 0, auto;
    }

    button,
    a,
    .game-card,
    .tab-btn,
    .contact-link,
    [role="button"],
    input[type="button"],
    input[type="heroSection"] input[type="submit"] {
      cursor: url('https://cdn.jsdelivr.net/gh/greeniYT/gug@main/assets/c.png') 0 0, auto !important;
    }

    #spaceBackground {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      background: linear-gradient(135deg, #020205 0%, #0a0810 50%, #010103 100%);
      transition: background 0.3s ease;
    }

    body.light-mode #spaceBackground {
      background: linear-gradient(135deg, #0a0e27 0%, #1a0033 50%, #0f0a2e 100%);
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      opacity: 0;
      animation: twinkle 3s infinite;
    }

    @keyframes twinkle {

      0%,
      100% {
        opacity: 0.3;
      }

      50% {
        opacity: 1;
      }
    }

    .nebula {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.1;
      pointer-events: none;
    }

    .nebula-purple {
      background: radial-gradient(circle, #9945ff, transparent);
    }

    .nebula-cyan {
      background: radial-gradient(circle, #00d9ff, transparent);
    }

    .nebula-pink {
      background: radial-gradient(circle, #ff006e, transparent);
    }

    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
      pointer-events: none;
      z-index: 0;
    }

    body.light-mode {
      background: #F5F5F5;
      color: #1F1F1F;
    }

    body.light-mode::before {
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.05) 100%);
    }

    .content {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      background: rgba(15, 15, 15, 0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      position: sticky;
      top: 0;
      z-index: 100;
      transition: all 0.3s ease;
    }

    body.light-mode header {
      background: rgba(255, 255, 255, 0.85);
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    .back-btn {
      background: var(--xbox-gray);
      border: none;
      color: var(--xbox-light);
      padding: 10px 24px;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      transition: all 0.2s ease;
      display: none;
      align-items: center;
      gap: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .back-btn:hover {
      background: var(--xbox-green);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(16, 124, 16, 0.4);
    }

    body.light-mode .back-btn {
      background: #E0E0E0;
      color: #1F1F1F;
    }

    body.light-mode .back-btn:hover {
      background: var(--xbox-green);
      color: white;
    }

    .site-logo {
      height: 40px;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .time-display {
      font-size: 18px;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.9);
      font-variant-numeric: tabular-nums;
    }

    body.light-mode .time-display {
      color: rgba(0, 0, 0, 0.8);
    }

    .menu-btn,
    .settings-btn {
      background: rgba(255, 255, 255, 0.1);
      border: none;
      color: var(--xbox-light);
      padding: 10px 16px;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    body.light-mode .menu-btn,
    body.light-mode .settings-btn {
      color: #1F1F1F;
      background: rgba(0, 0, 0, 0.08);
    }

    .menu-btn:hover,
    .settings-btn:hover {
      background: var(--xbox-green);
      color: white;
      transform: translateY(-1px);
    }

    .user-avatar {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--xbox-green), var(--xbox-accent));
      border-radius: 50%;
      display: none;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #000;
      cursor: pointer;
      transition: transform 0.2s;
    }

    .user-avatar:hover {
      transform: scale(1.1);
    }

    .main-content {
      flex: 1;
      padding: 40px;
      display: flex;
      flex-direction: column;
      gap: 40px;
      animation: fadeIn 0.6s ease-out 0.8s both;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .hero-section {
      position: relative;
      width: 100%;
      height: 400px;
      border-radius: 8px;
      overflow: hidden;
      background: var(--xbox-gray);
      cursor: pointer;
      transition: transform 0.3s ease;
      display: none;
    }

    body.light-mode .hero-section {
      background: #E0E0E0;
    }

    .hero-section.active {
      display: block;
    }

    .hero-section:hover {
      transform: scale(1.01);
    }

    .hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.8;
      transition: opacity 0.3s;
    }

    .hero-section:hover .hero-image {
      opacity: 0.6;
    }

    .hero-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 40px;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
    }

    .hero-badge {
      display: inline-block;
      background: var(--xbox-green);
      color: white;
      padding: 6px 16px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
    }

    .hero-title {
      font-size: 48px;
      font-weight: 300;
      margin-bottom: 12px;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    }

    .hero-subtitle {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.7);
      max-width: 600px;
      line-height: 1.5;
    }

    .hero-progress {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      background: var(--xbox-green);
      border-radius: 0;
      animation: progressBar 5s linear;
    }

    @keyframes progressBar {
      from {
        width: 0%;
      }

      to {
        width: 100%;
      }
    }

    .search-container {
      max-width: 600px;
      width: 100%;
    }

    .search-bar {
      width: 100%;
      padding: 16px 24px;
      font-size: 16px;
      border: none;
      border-radius: 4px;
      background: var(--xbox-gray);
      color: var(--xbox-light);
      transition: all 0.2s ease;
      outline: none;
      border: 2px solid transparent;
    }

    body.light-mode .search-bar {
      background: #E0E0E0;
      color: #1F1F1F;
    }

    body.light-mode .search-bar::placeholder {
      color: rgba(0, 0, 0, 0.4);
    }

    .search-bar:focus {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--xbox-green);
    }

    body.light-mode .search-bar:focus {
      background: rgba(0, 0, 0, 0.05);
      border-color: var(--xbox-green);
    }

    .search-bar::placeholder {
      color: rgba(255, 255, 255, 0.4);
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .section-title {
      font-size: 20px;
      font-weight: 600;
      color: var(--xbox-light);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    body.light-mode .section-title {
      color: #1F1F1F;
    }

    .section-title::before {
      content: '';
      width: 4px;
      height: 24px;
      background: var(--xbox-green);
      border-radius: 2px;
    }

    .view-all {
      color: rgba(255, 255, 255, 0.6);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s;
    }

    body.light-mode .view-all {
      color: rgba(0, 0, 0, 0.6);
    }

    .view-all:hover {
      color: var(--xbox-accent);
    }

    .games-grid-container {
      position: relative;
      width: 100%;
    }

    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 24px;
      padding: 20px 0;
    }

    .game-card {
      width: 100%;
      height: 270px;
      background: var(--xbox-gray);
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      border: 2px solid transparent;
    }

    body.light-mode .game-card {
      background: #E0E0E0;
    }

    .game-card:hover {
      transform: translateY(-8px) scale(1.02);
      border-color: var(--xbox-green);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(16, 124, 16, 0.3);
    }

    .game-card.featured {
      height: 270px;
    }

    .game-image {
      width: 100%;
      height: 180px;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .game-card.featured .game-image {
      height: 180px;
      position: relative;
      top: auto;
      left: auto;
      opacity: 1;
    }

    .game-card:hover .game-image {
      transform: scale(1.05);
    }

    .game-info {
      padding: 16px;
      position: relative;
      z-index: 2;
    }

    .game-card.featured .game-info {
      position: relative;
      bottom: auto;
      left: auto;
      right: auto;
      background: none;
    }

    .game-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--xbox-light);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-bottom: 4px;
    }

    body.light-mode .game-title {
      color: #1F1F1F;
    }

    .game-meta {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    body.light-mode .game-meta {
      color: rgba(0, 0, 0, 0.5);
    }

    .game-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      background: var(--xbox-green);
      color: white;
      border-radius: 3px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .play-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0);
      width: 60px;
      height: 60px;
      background: rgba(16, 124, 16, 0.95);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 3;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    }

    .play-overlay::after {
      content: '▶';
      color: white;
      font-size: 24px;
      margin-left: 4px;
    }

    .game-card:hover .play-overlay {
      transform: translate(-50%, -50%) scale(1);
    }

    .download-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0);
      width: 60px;
      height: 60px;
      background: rgba(16, 124, 16, 0.95);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 3;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    }

    .download-overlay::after {
      content: '⬇';
      color: white;
      font-size: 24px;
    }

    .game-card:hover .download-overlay {
      transform: translate(-50%, -50%) scale(1);
    }

    .no-results {
      text-align: center;
      padding: 80px 20px;
      color: rgba(255, 255, 255, 0.5);
      font-size: 18px;
      background: var(--xbox-gray);
      border-radius: 8px;
      margin: 20px 0;
    }

    body.light-mode .no-results {
      background: #E0E0E0;
      color: rgba(0, 0, 0, 0.5);
    }

    .scroll-btn {
      display: none;
    }

    .loading {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      color: rgba(255, 255, 255, 0.5);
      font-size: 16px;
      gap: 12px;
    }

    .spinner {
      width: 24px;
      height: 24px;
      border: 3px solid rgba(255, 255, 255, 0.1);
      border-top-color: var(--xbox-green);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    .error-message {
      text-align: center;
      padding: 40px;
      color: #ff4444;
      background: rgba(255, 68, 68, 0.1);
      border-radius: 8px;
      margin: 20px;
    }

    .error-message button {
      margin-top: 16px;
      padding: 10px 20px;
      background: var(--xbox-green);
      border: none;
      color: white;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .main-content {
        padding: 20px;
      }

      .game-card {
        height: 220px;
      }

      .game-card.featured {
        height: 220px;
      }

      .hero-title {
        font-size: 32px;
      }

      .intro-text {
        font-size: 24px;
      }
    }

    .tabs-container {
      display: flex;
      gap: 8px;
      margin-bottom: 40px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    body.light-mode .tabs-container {
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .tabs-container::-webkit-scrollbar {
      display: none;
    }

    .tab-btn {
      padding: 12px 24px;
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.6);
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      transition: all 0.2s ease;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    body.light-mode .tab-btn {
      color: rgba(0, 0, 0, 0.6);
    }

    .tab-btn:hover {
      color: rgba(255, 255, 255, 0.9);
    }

    body.light-mode .tab-btn:hover {
      color: rgba(0, 0, 0, 0.9);
    }

    .tab-btn.active {
      color: var(--xbox-light);
      border-bottom-color: var(--xbox-green);
    }

    body.light-mode .tab-btn.active {
      color: #1F1F1F;
      border-bottom-color: var(--xbox-green);
    }

    .modal {
      display: none;
      position: fixed;
      z-index: 5000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    .modal.active {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background: var(--xbox-gray);
      padding: 40px;
      border-radius: 8px;
      max-width: 500px;
      width: 90%;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
      animation: slideUp 0.3s ease;
    }

    body.light-mode .modal-content {
      background: #F0F0F0;
      color: #1F1F1F;
    }

    @keyframes slideUp {
      from {
        transform: translateY(30px);
        opacity: 0;
      }

      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      border-bottom: 2px solid var(--xbox-green);
      padding-bottom: 16px;
    }

    .modal-header h2 {
      font-size: 24px;
      font-weight: 600;
    }

    .close-modal {
      background: none;
      border: none;
      color: var(--xbox-light);
      font-size: 28px;
      cursor: pointer;
      transition: color 0.2s;
    }

    body.light-mode .close-modal {
      color: #1F1F1F;
    }

    .close-modal:hover {
      color: var(--xbox-green);
    }

    .settings-group {
      margin-bottom: 24px;
    }

    .settings-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 8px;
      color: rgba(255, 255, 255, 0.9);
    }

    body.light-mode .settings-group label {
      color: rgba(0, 0, 0, 0.9);
    }

    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 24px;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #ccc;
      transition: 0.3s;
      border-radius: 24px;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: 0.3s;
      border-radius: 50%;
    }

    input:checked+.slider {
      background-color: var(--xbox-green);
    }

    input:checked+.slider:before {
      transform: translateX(26px);
    }

    .volume-control {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }

    .volume-control input[type="range"] {
      flex: 1;
      height: 6px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.2);
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }

    body.light-mode .volume-control input[type="range"] {
      background: rgba(0, 0, 0, 0.2);
    }

    .volume-control input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--xbox-green);
      cursor: pointer;
      transition: all 0.2s;
    }

    .volume-control input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 10px rgba(16, 124, 16, 0.6);
    }

    .volume-control input[type="range"]::-moz-range-thumb {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--xbox-green);
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }

    .volume-control input[type="range"]::-moz-range-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 10px rgba(16, 124, 16, 0.6);
    }

    .volume-value {
      min-width: 40px;
      text-align: right;
      font-weight: 600;
      color: var(--xbox-accent);
    }

    .credits-section {
      margin-top: 24px;
    }

    .credits-section h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--xbox-accent);
    }

    .credits-section p {
      font-size: 14px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 8px;
    }

    body.light-mode .credits-section p {
      color: rgba(0, 0, 0, 0.7);
    }

    .credits-section a {
      color: var(--xbox-green);
      text-decoration: none;
